@model InventoryApp.Models.UserProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">

    @* ─── Profile Header ─────────────────────────────── *@
    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center gap-4">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center
                    justify-content-center"
                     style="width:80px; height:80px; font-size:2rem;">
                    @(Model.User.DisplayName?.FirstOrDefault() ?? 'U')
                </div>
                <div>
                    <h3 class="mb-1">@Model.User.DisplayName</h3>
                    <p class="text-muted mb-1">@Model.User.Email</p>
                    <small class="text-muted">
                        Member since @Model.User.CreatedAt.ToString("dd MMM yyyy")
                    </small>
                </div>
            </div>
        </div>
    </div>

    @* ─── My Inventories ─────────────────────────────── *@
    <div class="card shadow mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">📦 My Inventories (@Model.OwnedInventories.Count)</h5>
            <a asp-controller="Inventory" asp-action="Create"
               class="btn btn-primary btn-sm">+ New</a>
        </div>
        <div class="card-body p-0">
            @if (!Model.OwnedInventories.Any())
            {
                <div class="p-4 text-muted">
                    You haven't created any inventories yet.
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Items</th>
                            <th>Access</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.OwnedInventories)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Inventory"
                                           asp-action="Details"
                                           asp-route-id="@inv.Id">
                                        @inv.Title
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-primary">
                                        @inv.Items.Count
                                    </span>
                                </td>
                                <td>
                                    @if (inv.IsPublic)
                                    {
                                        <span class="badge bg-success">Public</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Private</span>
                                    }
                                </td>
                                <td>@inv.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-controller="Inventory"
                                       asp-action="Edit"
                                       asp-route-id="@inv.Id"
                                       class="btn btn-sm btn-outline-primary">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* ─── Access Inventories ──────────────────────────── *@
    <div class="card shadow">
        <div class="card-header">
            <h5 class="mb-0">
                🔑 Inventories I can write to (@Model.AccessInventories.Count)
            </h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.AccessInventories.Any())
            {
                <div class="p-4 text-muted">
                    You don't have write access to any other inventories.
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Owner</th>
                            <th>Items</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.AccessInventories)
                        {
                            <tr style="cursor:pointer"
                                onclick="location.href='@Url.Action("Details", "Inventory", new { id = inv.Id })'">
                                <td>@inv.Title</td>
                                <td>@(inv.Owner?.DisplayName ?? inv.Owner?.Email)</td>
                                <td>
                                    <span class="badge bg-primary">@inv.Items.Count</span>
                                </td>
                                <td>@inv.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>