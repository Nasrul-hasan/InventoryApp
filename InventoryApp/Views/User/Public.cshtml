@model InventoryApp.Models.UserProfileViewModel

@{
    ViewData["Title"] = Model.User.DisplayName + "'s Profile";
}

<div class="container mt-4">

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center gap-4">
                <div class="bg-secondary text-white rounded-circle d-flex
                    align-items-center justify-content-center"
                     style="width:80px; height:80px; font-size:2rem;">
                    @(Model.User.DisplayName?.FirstOrDefault() ?? 'U')
                </div>
                <div>
                    <h3 class="mb-1">@Model.User.DisplayName</h3>
                    <small class="text-muted">
                        Member since @Model.User.CreatedAt.ToString("dd MMM yyyy")
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-header">
            <h5 class="mb-0">
                📦 Inventories (@Model.OwnedInventories.Count)
            </h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.OwnedInventories.Any())
            {
                <div class="p-4 text-muted">No inventories yet.</div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Items</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.OwnedInventories)
                        {
                            <tr style="cursor:pointer"
                                onclick="location.href='@Url.Action("Details", "Inventory", new { id = inv.Id })'">
                                <td>@inv.Title</td>
                                <td>
                                    <span class="badge bg-primary">@inv.Items.Count</span>
                                </td>
                                <td>@inv.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>