@model InventoryApp.Models.CreateItemViewModel

@{
    ViewData["Title"] = "Add Item";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Add Item to: @Model.InventoryTitle</h5>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form asp-action="Create" method="post">
                        <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

                        @* Custom ID *@
                        <div class="mb-3">
                            <label class="form-label fw-bold">Custom ID</label>
                            <input type="text" name="customId"
                                   class="form-control font-monospace"
                                   value="@Model.CustomId" required />
                            <div class="form-text">
                                Unique ID for this item within the inventory.
                            </div>
                        </div>

                        <hr />

                        @* Custom Fields *@
                        @foreach (var field in Model.Fields)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    @field.Title
                                    @if (!string.IsNullOrEmpty(field.Description))
                                    {
                                        <span class="text-muted fw-normal small ms-1">
                                            — @field.Description
                                        </span>
                                    }
                                </label>

                                @switch (field.FieldType)
                                {
                                    case InventoryApp.Models.FieldType.SingleLineText:
                                        <input type="text"
                                               name="fieldValues[@field.Id]"
                                               class="form-control" />
                                        break;

                                    case InventoryApp.Models.FieldType.MultiLineText:
                                        <textarea name="fieldValues[@field.Id]"
                                                  class="form-control" rows="3"></textarea>
                                        break;

                                    case InventoryApp.Models.FieldType.Numeric:
                                        <input type="number"
                                               name="fieldValues[@field.Id]"
                                               class="form-control" step="any" />
                                        break;

                                    case InventoryApp.Models.FieldType.DocumentLink:
                                        <input type="url"
                                               name="fieldValues[@field.Id]"
                                               class="form-control"
                                               placeholder="https://..." />
                                        break;

                                    case InventoryApp.Models.FieldType.TrueFalse:
                                        <div class="form-check">
                                            <input type="checkbox"
                                                   name="fieldValues[@field.Id]"
                                                   class="form-check-input"
                                                   value="true" />
                                            <label class="form-check-label">Yes</label>
                                        </div>
                                        break;
                                }
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Save Item</button>
                            <a asp-controller="Inventory"
                               asp-action="Details"
                               asp-route-id="@Model.InventoryId"
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>