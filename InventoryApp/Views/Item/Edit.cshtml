@model InventoryApp.Models.EditItemViewModel

@{
    ViewData["Title"] = "Edit Item";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">Edit Item — @Model.InventoryTitle</h5>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form asp-action="Edit" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="inventoryId" value="@Model.InventoryId" />
                        <input type="hidden" name="version" value="@Model.Version" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Custom ID</label>
                            <input type="text" name="customId"
                                   class="form-control font-monospace"
                                   value="@Model.CustomId" required />
                        </div>

                        <hr />

                        @foreach (var field in Model.Fields)
                        {
                            var currentValue = Model.FieldValues
                                .ContainsKey(field.Id)
                                    ? Model.FieldValues[field.Id]
                                    : "";

                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    @field.Title
                                    @if (!string.IsNullOrEmpty(field.Description))
                                    {
                                        <span class="text-muted fw-normal small ms-1">
                                            — @field.Description
                                        </span>
                                    }
                                </label>

                                @switch (field.FieldType)
                                {
                                    case InventoryApp.Models.FieldType.SingleLineText:
                                        <input type="text"
                                               name="fieldValues[@field.Id]"
                                               class="form-control"
                                               value="@currentValue" />
                                        break;

                                    case InventoryApp.Models.FieldType.MultiLineText:
                                        <textarea name="fieldValues[@field.Id]"
                                                  class="form-control"
                                                  rows="3">@currentValue</textarea>
                                        break;

                                    case InventoryApp.Models.FieldType.Numeric:
                                        <input type="number"
                                               name="fieldValues[@field.Id]"
                                               class="form-control"
                                               value="@currentValue"
                                               step="any" />
                                        break;

                                    case InventoryApp.Models.FieldType.DocumentLink:
                                        <input type="url"
                                               name="fieldValues[@field.Id]"
                                               class="form-control"
                                               value="@currentValue"
                                               placeholder="https://..." />
                                        break;

                                    case InventoryApp.Models.FieldType.TrueFalse:
                                        <div class="form-check">
                                            <input type="checkbox"
                                                   name="fieldValues[@field.Id]"
                                                   class="form-check-input"
                                                   value="true"
                                            @(currentValue == "true" ? "checked" : "") />
                                            <label class="form-check-label">Yes</label>
                                        </div>
                                        break;
                                }
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning">Save Changes</button>
                            <a asp-action="Details" asp-route-id="@Model.Id"
                               class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>