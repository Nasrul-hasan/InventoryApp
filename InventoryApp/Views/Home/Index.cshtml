@model InventoryApp.Models.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">

    @* ─── Hero Section ─────────────────────────────────── *@
    <div class="p-4 mb-4 bg-primary text-white rounded-3">
        <h1 class="display-6 fw-bold">📦 Inventory Manager</h1>
        <p class="lead mb-3">
            Create and manage custom inventories for anything —
            office equipment, books, HR documents, and more.
        </p>
        @if (!User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-light btn-lg me-2">Get Started</a>
            <a asp-controller="Account" asp-action="Login"
               class="btn btn-outline-light btn-lg">Login</a>
        }
        else
        {
            <a asp-controller="Inventory" asp-action="Create"
               class="btn btn-light btn-lg">+ New Inventory</a>
        }
    </div>

    <div class="row g-4">

        @* ─── Latest Inventories ────────────────────────── *@
        <div class="col-lg-8">
            <div class="card shadow h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">🕐 Latest Inventories</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.LatestInventories.Any())
                    {
                        <div class="p-4 text-muted">No inventories yet.</div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Owner</th>
                                    <th>Items</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in Model.LatestInventories)
                                {
                                    <tr style="cursor:pointer"
                                        onclick="location.href='@Url.Action("Details", "Inventory", new { id = inv.Id })'">
                                        <td>
                                            <strong>@inv.Title</strong>
                                            @if (!string.IsNullOrEmpty(inv.Description))
                                            {
                                                <br />
                                                <small class="text-muted">
                                                    @(inv.Description.Length > 50
                                                        ? inv.Description[..50] + "..."
                                                        : inv.Description)
                                                </small>
                                            }
                                        </td>
                                        <td>@(inv.Owner?.DisplayName ?? inv.Owner?.Email)</td>
                                        <td>
                                            <span class="badge bg-primary">
                                                @inv.Items.Count
                                            </span>
                                        </td>
                                        <td>@inv.CreatedAt.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        @* ─── Right Column ───────────────────────────────── *@
        <div class="col-lg-4">

            @* Top 5 Popular *@
            <div class="card shadow mb-4">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">🏆 Top 5 Popular</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.TopInventories.Any())
                    {
                        <div class="p-3 text-muted">No data yet.</div>
                    }
                    else
                    {
                        <table class="table mb-0">
                            <tbody>
                                @{
                                    int rank = 1;
                                }
                                @foreach (var inv in Model.TopInventories)
                                {
                                    <tr style="cursor:pointer"
                                        onclick="location.href='@Url.Action("Details", "Inventory", new { id = inv.Id })'">
                                        <td>
                                            <span class="badge bg-warning text-dark">
                                                #@rank
                                            </span>
                                        </td>
                                        <td>@inv.Title</td>
                                        <td>
                                            <span class="badge bg-primary">
                                                @inv.Items.Count items
                                            </span>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            @* Tag Cloud *@
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">🏷️ Tag Cloud</h5>
                </div>
                <div class="card-body">
                    @if (!Model.PopularTags.Any())
                    {
                        <p class="text-muted">No tags yet.</p>
                    }
                    else
                    {
                        @foreach (var tag in Model.PopularTags)
                        {
                            var count = tag.InventoryTags.Count;
                            var size = count > 5 ? "fs-5" :
                                       count > 3 ? "fs-6" : "small";
                            <a href="/Inventory?tag=@tag.Name"
                                   class="badge bg-secondary text-decoration-none me-1 mb-1 @size">
                                @tag.Name (@count)
                            </a>
                        }
                    }
                </div>
            </div>

        </div>
    </div>
</div>